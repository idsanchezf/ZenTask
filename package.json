{
    "name": "zentask",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test:bdd": "cypress run",
        "report:generate": "node ./generate-report.js",
        "report:open": "npx serve cypress/reports/html"
    },
    "dependencies": {
        "vue": "^3.4.21",
        "vue-router": "^4.3.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.4",
        "cypress": "^13.7.1",
        "@badeball/cypress-cucumber-preprocessor": "^20.0.2",
        "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
        "vite": "^5.2.0",
        "multiple-cucumber-html-reporter": "^3.6.2"
    },
    "cypress-cucumber-preprocessor": {
        "stepDefinitions": [
            "cypress/e2e/step_definitions/**/*.{js,ts}"
        ],
        "json": {
            "enabled": true,
            "output": "cypress/reports/cucumber-results.json"
        }
    }
}